<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".store.PostDataOffiineFragment">

    <!-- TODO: Update blank fragment layout -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:layout_margin="3dp">
            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="3dp"
                android:layout_weight="1">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_margin="2dp"
                    android:padding="5dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="3dp">

                        <TextView
                            android:layout_weight="1"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="Site"
                            android:textSize="15sp" />

                        <EditText
                            android:layout_weight="1.3"
                            android:textSize="15sp"
                            android:id="@+id/site"
                            android:layout_width="0dp"
                            android:singleLine="true"
                            android:layout_height="wrap_content"
                            android:hint="Site" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="3dp">

                        <TextView
                            android:layout_weight="1"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="Employee Id"
                            android:textSize="15sp" />

                        <EditText
                            android:layout_weight="1.3"
                            android:textSize="15sp"
                            android:id="@+id/employeeId"
                            android:layout_width="0dp"
                            android:imeOptions="actionNext"
                            android:singleLine="true"
                            android:layout_height="wrap_content"
                            android:hint="Employee Id" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="10dp"
                        android:padding="3dp">

                        <TextView
                            android:layout_weight="1.1"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="Irod"
                            android:textSize="15sp" />

                        <EditText
                            android:layout_weight="1"
                            android:textSize="15sp"
                            android:id="@+id/irod"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:singleLine="true"
                            android:hint="Irod" />

                        <Button
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight=".5"
                            android:text="Scan"
                            android:layout_margin="2dp"
                            android:background="@drawable/shadow"
                            android:id="@+id/irodScan"
                            />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="3dp">

                        <TextView
                            android:layout_weight="1.1"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="Barcode"
                            android:textSize="15sp" />

                        <EditText
                            android:id="@+id/barcode"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="Barcode"
                            android:imeOptions="actionDone"
                            android:maxLines="1"
                            android:singleLine="true"
                            android:textSize="15sp" />

                        <Button
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight=".5"
                            android:text="Scan"
                            android:layout_margin="2dp"
                            android:background="@drawable/shadow"
                            android:id="@+id/barcodeScan"
                            />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="3dp">

                        <TextView
                            android:layout_weight="1"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="Barcode Scanned"
                            android:textSize="15sp" />


                        <EditText
                            android:id="@+id/barcodeScanned"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1.3"
                            android:hint="Barcode Scanned"
                            android:imeOptions="actionSearch"
                            android:inputType="text"
                            android:maxLines="1"
                            android:singleLine="true"
                            android:textSize="15sp" />


                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="3dp">

                        <TextView
                            android:layout_weight="1"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="Scan Qty"
                            android:textSize="15sp" />

                        <EditText
                            android:layout_weight="1.3"
                            android:textSize="15sp"
                            android:id="@+id/scanQty"
                            android:layout_width="0dp"
                            android:focusable="false"
                            android:layout_height="wrap_content"
                            android:hint="Scan Qty" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="3dp">

                        <TextView
                            android:layout_weight="1"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="Total Scan Qty"
                            android:textSize="15sp" />

                        <EditText
                            android:id="@+id/totalScanQty"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1.3"
                            android:hint="Total Scan Qty"
                            android:imeOptions="actionSearch"
                            android:inputType="text"
                            android:focusable="false"
                            android:maxLines="1"
                            android:singleLine="true"
                            android:textSize="15sp" />
                    </LinearLayout>


                </LinearLayout>
            </ScrollView>

            <TextView
                android:id="@+id/response"
                android:layout_weight="0"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_margin="2dp"
                android:padding="5dp"
                android:text="status:"
                android:visibility="gone"
                android:textColor="@color/colorPrimary" />

            <LinearLayout
                android:layout_weight="0"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:layout_marginEnd="8dp"
                android:layout_gravity="end"
                android:layout_marginLeft="8dp"
                android:layout_marginRight="8dp"
                android:layout_marginStart="8dp"
                android:layout_marginTop="8dp"
                android:orientation="horizontal"
                android:padding="3dp"
                >

           <RadioGroup android:id="@+id/sizeToggleGroup"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:layout_marginRight="8dp"
                android:orientation="horizontal"
            >

            <ToggleButton android:id="@+id/btn_size_ml"
                  android:layout_height="wrap_content"
                  android:layout_width="65dp"
                  android:layout_weight="1"
                  android:textSize="14sp"
                  android:textOn="N-L"
                  android:textOff="N-L"
            />
            <ToggleButton android:id="@+id/btn_size_rl"
                android:layout_height="wrap_content"
                android:layout_width="65dp"
                android:layout_weight="1"
                android:textSize="14sp"
                android:textOn="R-L"
                android:textOff="R-L"
                    />
           <ToggleButton android:id="@+id/btn_size_m"
               android:layout_height="wrap_content"
               android:layout_width="50dp"
               android:layout_weight="1"
               android:textSize="14sp"
               android:textOn="M"
               android:textOff="M"
               />
           <ToggleButton android:id="@+id/btn_size_c"
               android:layout_height="wrap_content"
               android:layout_width="50dp"
               android:layout_weight="1"
               android:textSize="14sp"
               android:textOn="C"
               android:textOff="C"
               />
           <ToggleButton android:id="@+id/btn_size_v2s"
               android:layout_height="wrap_content"
               android:layout_width="50dp"
               android:layout_weight="1"
               android:textSize="14sp"
               android:textOn="V2S"
               android:textOff="V2S"
               />
            </RadioGroup>

                <Button
                    android:id="@+id/save"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="2dp"
                    android:gravity="center"
                    android:layout_gravity="center"
                    android:background="@drawable/shadow"
                    android:hint=""
                    android:text="Save"
                    android:textSize="15sp" />
            </LinearLayout>
        </LinearLayout>

    </ScrollView>

</FrameLayout>