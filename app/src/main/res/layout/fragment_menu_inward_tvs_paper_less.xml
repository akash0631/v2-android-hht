<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/bgPage">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_margin="2dp" android:background="#000" android:padding="5dp">
        <Button android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_margin="5dp" android:textColor="@color/white" android:id="@+id/btn_tvs_paperless_picking" android:background="@drawable/bg_btn_primary" android:text="Picking" android:textSize="13sp" />
        <Button android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_margin="5dp" android:textColor="@color/white" android:id="@+id/btn_tvs_paperless_picking_confirm" android:background="@drawable/bg_btn_primary" android:text="Picking Confirmation" android:textSize="13sp" />
        <Button android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_margin="5dp" android:textColor="@color/white" android:id="@+id/btn_tvs_paperless_re_print" android:background="@drawable/bg_btn_primary" android:text="Re-Print" android:textSize="13sp" />
        <Button android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_margin="5dp" android:textColor="@color/white" android:id="@+id/btn_tvs_paperless_test_print" android:background="@drawable/bg_btn_primary" android:text="Test Print" android:textSize="13sp" />
    </LinearLayout>
</FrameLayout>