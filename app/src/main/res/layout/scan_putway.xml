<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="2dp"
            android:padding="5dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="5dp">

                <TextView
                    android:layout_weight=".9"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Crate"
                    android:textSize="15sp" />

                <EditText
                    android:layout_weight="1"
                    android:textSize="15sp"
                    android:id="@+id/crate_no"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:hint="Enter Crate No." />

                <Button
                    android:layout_weight="0.5"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Scan"
                    android:id="@+id/crate_scan"
                    android:layout_margin="2dp"
                    android:padding="2dp"
                    android:background="@drawable/shadow" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="5dp">

                <TextView
                    android:layout_weight=".9"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Dest Bin"
                    android:textSize="15sp" />

                <EditText
                    android:layout_weight="1"
                    android:textSize="15sp"
                    android:id="@+id/dest_bin_no"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:hint="Dest Bin" />

                <Button
                    android:layout_weight="0.5"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Scan"
                    android:id="@+id/dest_scan"
                    android:layout_margin="2dp"
                    android:padding="2dp"
                    android:background="@drawable/shadow" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="5dp">

                <TextView
                    android:layout_weight=".9"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="PO"
                    android:textSize="15sp" />

                <EditText
                    android:layout_weight="1.5"
                    android:textSize="15sp"
                    android:enabled="true"
                    android:focusable="false"
                    android:id="@+id/po_no"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:hint="PO No." />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="5dp">

                <TextView
                    android:layout_weight=".9"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Total Scanned"
                    android:textSize="15sp" />

                <EditText
                    android:layout_weight="1.5"
                    android:textSize="15sp"
                    android:enabled="true"
                    android:focusable="false"
                    android:id="@+id/total_scanned"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:hint="Total Scanned" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="5dp">

                <TextView
                    android:layout_weight=".9"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Crate Qty"
                    android:textSize="15sp" />

                <EditText
                    android:layout_weight="1.5"
                    android:textSize="15sp"
                    android:id="@+id/crate_qty"
                    android:enabled="true"
                    android:focusable="false"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:hint="Crate Qty" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="5dp">

                <TextView
                    android:layout_weight=".9"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Total Crate Qty"
                    android:textSize="15sp" />

                <EditText
                    android:layout_weight="1.5"
                    android:textSize="15sp"
                    android:id="@+id/total_crate_qty"
                    android:layout_width="0dp"
                    android:enabled="true"
                    android:focusable="false"
                    android:layout_height="wrap_content"
                    android:hint="Total Crate Qty" />
            </LinearLayout>

            <TextView
                android:id="@+id/response"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_margin="2dp"
                android:padding="5dp"
                android:text="status:"

                android:visibility="gone"
                android:textColor="@color/colorPrimary" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="5dp">

            <Button
                android:layout_weight="1.5"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Back"
                android:id="@+id/back"
                android:background="@drawable/shadow"
                android:layout_margin="2dp"
                android:textSize="15sp" />

            <Button
                android:layout_weight="1.5"
                android:textSize="15sp"
                android:text="Crate TO"
                android:id="@+id/crate_to"
                android:background="@drawable/shadow"
                android:layout_margin="2dp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:hint="" />
        </LinearLayout>

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>