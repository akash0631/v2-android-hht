<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent">
    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="5dp" android:layout_margin="2dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="5dp">
                <TextView android:layout_weight=".8" android:layout_width="0dp" android:layout_height="wrap_content" android:text="HU Number" android:textSize="15sp" />
                <EditText android:layout_weight="1.5" android:textSize="15sp" android:layout_width="0dp" android:enabled="false" android:id="@+id/store_name" android:layout_height="48dp" android:hint="Enter HU No." android:background="@color/bgInput" android:textColor="@color/textPrimary" android:textColorHint="@color/textHint" android:paddingStart="14dp" android:paddingEnd="14dp" />
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="5dp">
                <TextView android:layout_weight=".8" android:layout_width="0dp" android:layout_height="wrap_content" android:text="HU Qty" android:textSize="15sp" />
                <EditText android:layout_weight="1.5" android:textSize="15sp" android:inputType="date" android:id="@+id/date" android:layout_width="0dp" android:layout_height="48dp" android:hint="HU QTy  " android:background="@color/bgInput" android:textColor="@color/textPrimary" android:textColorHint="@color/textHint" android:paddingStart="14dp" android:paddingEnd="14dp" />
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="5dp">
                <TextView android:layout_weight=".8" android:layout_width="0dp" android:layout_height="wrap_content" android:text="Scanned HU's" android:textSize="15sp" />
                <EditText android:layout_weight="1.5" android:textSize="15sp" android:inputType="date" android:id="@+id/scanned_hu" android:layout_width="0dp" android:layout_height="48dp" android:hint="Scanned Hu  " android:background="@color/bgInput" android:textColor="@color/textPrimary" android:textColorHint="@color/textHint" android:paddingStart="14dp" android:paddingEnd="14dp" />
            </LinearLayout>
            <TextView android:id="@+id/response" android:layout_width="match_parent" android:layout_height="60dp" android:layout_margin="2dp" android:padding="5dp" android:text="status:" android:visibility="gone" android:textColor="@color/colorPrimary" />
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="5dp">
            <Button android:layout_weight="2" android:textSize="15sp" android:layout_margin="2dp" android:background="@drawable/bg_btn_primary" android:text="Transfer To CLA" android:id="@+id/next" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/white" />
        </LinearLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>