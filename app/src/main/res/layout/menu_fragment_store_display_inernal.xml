<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:id="@+id/displayInternalStoreMenu">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="2dp"
            android:background="@color/black"
            android:padding="5dp"
            android:tag="store_display_tag">

            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="5dp"
                android:textColor="@color/white"
                android:id="@+id/store_display_internal_art_irod"
                android:background="@color/buttonColor"
                android:text="Art IROD Identifier" />
            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="5dp"
                android:textColor="@color/white"
                android:id="@+id/store_display_internal_tagging_irod"
                android:background="@color/buttonColor"
                android:text="Tagging IROD With Gandola" />
            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="5dp"
                android:textColor="@color/white"
                android:id="@+id/store_display_internal_detagging_irod"
                android:background="@color/buttonColor"
                android:text="De-Tagging IROD With Gandola" />
            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="5dp"
                android:textColor="@color/white"
                android:id="@+id/store_display_internal_irod_nature"
                android:background="@color/buttonColor"
                android:text="IROD Nature Assignment" />
            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="5dp"
                android:textColor="@color/white"
                android:id="@+id/store_display_internal_irod_to_irod"
                android:background="@color/buttonColor"
                android:text="IROD To IROD" />
        </LinearLayout>
    </ScrollView>
</FrameLayout>