<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:tools="http://schemas.android.com/tools" android:layout_width="match_parent" android:layout_height="match_parent" tools:context=".dc.ShadeStockMovementFragment" android:background="@color/bgPage">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_margin="2dp" android:background="#000" android:padding="5dp">
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_margin="5dp" android:textColor="#fff" android:layout_weight="1" android:id="@+id/hp_scan_in_pallete" android:text="Select Process" />
        <Button android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Picking " android:id="@+id/picking" android:layout_margin="5dp" android:textColor="@color/white" android:background="@drawable/bg_btn_primary" android:textSize="13sp" />
        <Button android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Putway" android:id="@+id/putway" android:layout_margin="5dp" android:layout_weight="1" android:textColor="@color/white" android:background="@drawable/bg_btn_primary" android:textSize="13sp" />
    </LinearLayout>
</FrameLayout>