<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- TODO: Update blank fragment layout -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_margin="2dp"
        android:background="#000"
        android:padding="5dp">

        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="5dp"
            android:textColor="#fff"
            android:id="@+id/btn_hu_in_bin_direct_bin"
            android:background="#e71821"
            android:text="Direct Bin" />

        <Button
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="HU To Pallet"
            android:layout_margin="5dp"
            android:textColor="#fff"
            android:id="@+id/btn_hu_in_bin_hu_to_pallet"
            android:background="#e71821" />

        <Button
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="Pallet To Bin"
            android:layout_margin="5dp"
            android:textColor="#fff"
            android:id="@+id/btn_hu_in_bin_pallet_to_bin"
            android:background="#e71821" />


    </LinearLayout>

</FrameLayout>