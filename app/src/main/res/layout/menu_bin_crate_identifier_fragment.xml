<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="com.v2retail.dotvik.dc.DC_DashBoard">

    <!-- TODO: Update blank fragment layout -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_margin="2dp"
        android:background="#000"
        android:padding="5dp">

        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="5dp"
            android:textColor="#fff"

            android:id="@+id/bin_crate_identifier_bin"
            android:background="#e71821"
            android:text="Bin Identifier" />

        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Crate Identifier"
            android:layout_margin="5dp"
            android:textColor="#fff"

            android:id="@+id/bin_crate_identifier_crate"
            android:background="#e71821" />
    </LinearLayout>

</FrameLayout>