<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- TODO: Update blank fragment layout -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_margin="2dp"
        android:background="#000"
        android:padding="5dp">
        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Crate Picking"
            android:id="@+id/grt_combo_pick_crate_picking"
            android:layout_margin="5dp"
            android:textColor="#fff"
            android:background="#e71821" />
        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Palette Putway"
            android:id="@+id/grt_combo_pick_palette_putway"
            android:layout_margin="5dp"
            android:textColor="#fff"
            android:background="#e71821" />
        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Palette Receive"
            android:id="@+id/grt_combo_pick_palette_receive"
            android:layout_margin="5dp"
            android:textColor="#fff"
            android:background="#e71821" />
        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tag HU with Store Zone"
            android:id="@+id/btn_combo_hu_zone_store"
            android:layout_margin="5dp"
            android:textColor="#fff"
            android:background="#e71821" />
        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Crate Scan"
            android:id="@+id/btn_grt_combo_crate_scanning"
            android:layout_margin="5dp"
            android:textColor="#fff"
            android:background="#e71821" />
        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="DE TAG HUS"
            android:id="@+id/btn_grt_combo_pick_de_tag_hu"
            android:layout_margin="5dp"
            android:textColor="#fff"
            android:background="#e71821" />
        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Crate To MSA Bin"
            android:id="@+id/grt_combo_crate_to_msa_bin"
            android:layout_margin="5dp"
            android:textColor="#fff"
            android:background="#e71821" />
        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="HU PICKING"
            android:id="@+id/grt_combo_hu_pick"
            android:layout_margin="5dp"
            android:textColor="#fff"
            android:background="#e71821" />
    </LinearLayout>

</FrameLayout>