<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="2dp"
            android:background="#000"
            android:padding="5dp">

            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="5dp"
                android:textColor="#fff"

                android:id="@+id/ptl_new_full_crate_ptl_picking"
                android:background="#e71821"
                android:text="PTL Picking" />

            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Pallate Tag With FLR BIN"
                android:layout_margin="5dp"
                android:textColor="#fff"
                android:id="@+id/ptl_new_full_crate_flr_bin"
                android:background="#e71821" />

            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Create Move To FLR Stagging"
                android:id="@+id/ptl_new_full_crate_move_flr_staging"
                android:layout_margin="5dp"
                android:textColor="#fff"
                android:background="#e71821" />

            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Pallate Receive at Floor"
                android:id="@+id/ptl_new_full_crate_receive_at_floor"
                android:layout_margin="5dp"
                android:textColor="#fff"
                android:background="#e71821" />
            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="PLT Receive at HUB Station"
                android:id="@+id/ptl_new_full_crate_receive_at_hub_station"
                android:layout_margin="5dp"
                android:textColor="#fff"
                android:background="#e71821" />
            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="HUB STN/Crate/Zone Mapping"
                android:id="@+id/ptl_new_full_crate_hu_stn_crate_zone_mapping"
                android:layout_margin="5dp"
                android:textColor="#fff"
                android:background="#e71821" />
            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Crate Putway (Sorting) Zone-Wise"
                android:id="@+id/ptl_new_full_crate_putway_sorting_zone_wise"
                android:layout_margin="5dp"
                android:textColor="#fff"
                android:background="#e71821" />
            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Receive At Zone"
                android:id="@+id/ptl_new_full_crate_receive_at_zone"
                android:layout_margin="5dp"
                android:textColor="#fff"
                android:background="#e71821" />
            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="HU/Zone/Store Mapping"
                android:id="@+id/ptl_new_full_crate_hu_zone_store_mapping"
                android:layout_margin="5dp"
                android:textColor="#fff"
                android:background="#e71821" />
        </LinearLayout>
    </ScrollView>
</FrameLayout>