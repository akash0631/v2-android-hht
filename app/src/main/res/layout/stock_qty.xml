<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <ScrollView
            android:layout_weight="1"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_margin="2dp"
                android:padding="5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="5dp"
                    android:layout_weight="0">

                    <TextView
                        android:layout_weight=".9"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Article No"
                        android:textSize="15sp" />

                    <EditText
                        android:layout_weight="1.5"
                        android:textSize="15sp"
                        android:id="@+id/ean_et"
                        android:layout_width="0dp"
                        android:enabled="true"
                        android:focusable="false"
                        android:layout_height="wrap_content"
                        android:hint="Article No." />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="5dp"
                    android:layout_weight="0">

                    <TextView
                        android:layout_weight=".9"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Article "
                        android:textSize="15sp" />

                    <EditText
                        android:layout_weight="1.5"
                        android:textSize="15sp"
                        android:id="@+id/article_et"
                        android:layout_width="0dp"
                        android:enabled="true"
                        android:focusable="false"
                        android:layout_height="wrap_content"
                        android:hint="Barcode " />
                </LinearLayout>

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="5dp"
                    android:columnCount="4"
                    android:padding="2dp"
                    android:rowCount="6">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_column="0"
                        android:layout_columnWeight=".5"
                        android:layout_row="0"
                        android:hint="V01 "
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <EditText

                        android:id="@+id/vo1_et"
                        android:layout_width="90dp"
                        android:layout_height="wrap_content"
                        android:layout_column="1"
                        android:layout_columnWeight="1.5"
                        android:layout_row="0"
                        android:enabled="true"
                        android:focusable="false"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_column="2"
                        android:layout_columnWeight=".5"
                        android:layout_row="0"
                        android:hint="V02"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <EditText

                        android:id="@+id/msa_et"
                        android:layout_width="90dp"
                        android:layout_height="wrap_content"
                        android:layout_column="3"
                        android:layout_columnWeight="1.5"
                        android:layout_row="0"
                        android:enabled="true"
                        android:focusable="false"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_column="0"
                        android:layout_columnWeight=".5"
                        android:layout_row="1"
                        android:hint="0001 "
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <EditText

                        android:id="@+id/one_et"
                        android:layout_width="90dp"
                        android:layout_height="wrap_content"
                        android:layout_column="1"
                        android:layout_columnWeight="1.5"
                        android:layout_row="1"
                        android:enabled="true"
                        android:focusable="false"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_column="2"
                        android:layout_columnWeight=".5"
                        android:layout_row="1"
                        android:hint="0003 "
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <EditText

                        android:id="@+id/three_et"
                        android:layout_width="90dp"
                        android:layout_height="wrap_content"
                        android:layout_column="3"
                        android:layout_columnWeight="1.5"
                        android:layout_row="1"
                        android:enabled="true"
                        android:focusable="false"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_column="0"
                        android:layout_columnWeight=".5"
                        android:layout_row="2"
                        android:hint="0004"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <EditText

                        android:id="@+id/four_et"
                        android:layout_width="90dp"
                        android:layout_height="wrap_content"
                        android:layout_column="1"
                        android:layout_columnWeight="1.5"
                        android:layout_row="2"
                        android:enabled="true"
                        android:focusable="false"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_column="2"
                        android:layout_columnWeight=".5"
                        android:layout_row="2"
                        android:hint="0005"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <EditText

                        android:id="@+id/five_et"
                        android:layout_width="90dp"
                        android:layout_height="wrap_content"
                        android:layout_column="3"
                        android:layout_columnWeight="1.5"
                        android:layout_row="2"
                        android:enabled="true"
                        android:focusable="false"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_column="0"
                        android:layout_columnWeight=".5"
                        android:layout_row="3"
                        android:hint="0006"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <EditText

                        android:id="@+id/six_et"
                        android:layout_width="90dp"
                        android:layout_height="wrap_content"
                        android:layout_column="1"
                        android:layout_columnWeight="1.5"
                        android:layout_row="3"
                        android:enabled="true"
                        android:focusable="false"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_column="2"
                        android:layout_columnWeight=".5"
                        android:layout_row="4"
                        android:hint="0009"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <EditText

                        android:id="@+id/nine_et"
                        android:layout_width="90dp"
                        android:layout_height="wrap_content"
                        android:layout_column="3"
                        android:layout_columnWeight="1.5"
                        android:layout_row="4"
                        android:enabled="true"
                        android:focusable="false"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_column="0"
                        android:layout_columnWeight=".5"
                        android:layout_row="4"
                        android:hint="0008"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <EditText

                        android:id="@+id/eight_et"
                        android:layout_width="90dp"
                        android:layout_height="wrap_content"
                        android:layout_column="1"
                        android:layout_columnWeight="1.5"
                        android:layout_row="4"
                        android:enabled="true"
                        android:focusable="false"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_column="2"
                        android:layout_columnWeight=".5"
                        android:layout_row="3"
                        android:hint="0007"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <EditText

                        android:id="@+id/seven_et"
                        android:layout_width="90dp"
                        android:layout_height="wrap_content"
                        android:layout_column="3"
                        android:layout_columnWeight="1.5"
                        android:layout_row="3"
                        android:enabled="true"
                        android:focusable="false"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_column="0"
                        android:layout_columnWeight=".5"
                        android:layout_row="5"
                        android:hint="0010"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <EditText

                        android:id="@+id/ten_et"
                        android:layout_width="90dp"
                        android:layout_height="wrap_content"
                        android:layout_column="1"
                        android:layout_columnWeight="1.5"
                        android:layout_row="5"
                        android:enabled="true"
                        android:focusable="false"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_column="2"
                        android:layout_columnWeight=".5"
                        android:layout_row="5"
                        android:hint="Total"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <EditText

                        android:id="@+id/total_et"
                        android:layout_width="90dp"
                        android:layout_height="wrap_content"
                        android:layout_column="3"
                        android:layout_columnWeight="1.5"
                        android:layout_row="5"
                        android:enabled="true"
                        android:focusable="false"
                        android:textSize="15sp" />
                </GridLayout>



            </LinearLayout>
        </ScrollView>


        <LinearLayout
            android:orientation="horizontal"
            android:layout_margin="5dp"
            android:layout_weight="0"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <Button
                android:textSize="15sp"
                android:text="close"
                android:id="@+id/close"
                android:background="@drawable/shadow"
                android:padding="5dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="" />
        </LinearLayout>

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>