<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent">
    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_margin="2dp" android:orientation="vertical" android:padding="5dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="5dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight=".8" android:text="Packing Material" android:textSize="15sp" />
                <EditText android:id="@+id/store_name" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" android:enabled="false" android:hint="" android:textSize="15sp" android:background="@color/bgInput" android:textColor="@color/textPrimary" android:textColorHint="@color/textHint" android:paddingStart="14dp" android:paddingEnd="14dp" />
            </LinearLayout>
            <TextView android:id="@+id/response" android:layout_width="match_parent" android:layout_height="60dp" android:layout_margin="2dp" android:padding="5dp" android:text="status:" android:textColor="@color/colorPrimary" android:visibility="gone" />
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="5dp">
            <Button android:layout_weight="2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Back" android:layout_margin="12dp" android:background="@drawable/bg_btn_primary" android:id="@+id/back" android:textSize="15sp" android:textColor="@color/white" />
            <Button android:layout_weight="2" android:textSize="15sp" android:layout_margin="12dp" android:background="@drawable/bg_btn_primary" android:text="Next" android:id="@+id/next" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/white" />
        </LinearLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>