<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/bgPage">
    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="PTL 5.0" android:textSize="28sp" android:textStyle="bold" android:textColor="@color/textPrimary" android:letterSpacing="-0.02" android:layout_marginBottom="2dp" />
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Select a process to begin" android:textSize="12sp" android:textColor="@color/textLabel" android:layout_marginBottom="24dp" />
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                <LinearLayout android:id="@+id/ptl_picking" android:layout_width="0dp" android:layout_height="80dp" android:layout_weight="1" android:orientation="vertical" android:background="@color/bgCard" android:padding="14dp" android:layout_marginEnd="4dp" android:clickable="true" android:focusable="true">
                    <TextView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:text="PTL Picking" android:textSize="13sp" android:textStyle="bold" android:textColor="@color/textPrimary" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Active" android:textSize="9sp" android:textStyle="bold" android:textColor="@color/colorSuccess" android:background="@color/colorSuccessBg" android:paddingStart="7dp" android:paddingEnd="7dp" android:paddingTop="2dp" android:paddingBottom="2dp" />
                </LinearLayout>
                <LinearLayout android:id="@+id/ptl_crate_send" android:layout_width="0dp" android:layout_height="80dp" android:layout_weight="1" android:orientation="vertical" android:background="@color/bgCard" android:padding="14dp" android:layout_marginStart="4dp" android:clickable="true" android:focusable="true">
                    <TextView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:text="Floor staging" android:textSize="13sp" android:textStyle="bold" android:textColor="@color/textPrimary" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Crate tag PLT" android:textSize="9sp" android:textStyle="bold" android:textColor="@color/colorInfo" android:background="@color/statBlueBg" android:paddingStart="7dp" android:paddingEnd="7dp" android:paddingTop="2dp" android:paddingBottom="2dp" />
                </LinearLayout>
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                <LinearLayout android:id="@+id/ptl_floor_receive" android:layout_width="0dp" android:layout_height="80dp" android:layout_weight="1" android:orientation="vertical" android:background="@color/bgCard" android:padding="14dp" android:layout_marginEnd="4dp" android:clickable="true" android:focusable="true">
                    <TextView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:text="Floor receive" android:textSize="13sp" android:textStyle="bold" android:textColor="@color/textPrimary" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pallet at GF" android:textSize="9sp" android:textStyle="bold" android:textColor="@color/colorInfo" android:background="@color/statBlueBg" android:paddingStart="7dp" android:paddingEnd="7dp" android:paddingTop="2dp" android:paddingBottom="2dp" />
                </LinearLayout>
                <LinearLayout android:id="@+id/ptl_zone_receive" android:layout_width="0dp" android:layout_height="80dp" android:layout_weight="1" android:orientation="vertical" android:background="@color/bgCard" android:padding="14dp" android:layout_marginStart="4dp" android:clickable="true" android:focusable="true">
                    <TextView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:text="Zone receive" android:textSize="13sp" android:textStyle="bold" android:textColor="@color/textPrimary" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pallet at zone" android:textSize="9sp" android:textStyle="bold" android:textColor="@color/colorSuccess" android:background="@color/colorSuccessBg" android:paddingStart="7dp" android:paddingEnd="7dp" android:paddingTop="2dp" android:paddingBottom="2dp" />
                </LinearLayout>
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                <LinearLayout android:id="@+id/ptl_article_putway" android:layout_width="0dp" android:layout_height="80dp" android:layout_weight="1" android:orientation="vertical" android:background="@color/bgCard" android:padding="14dp" android:layout_marginEnd="4dp" android:clickable="true" android:focusable="true">
                    <TextView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:text="Article putway" android:textSize="13sp" android:textStyle="bold" android:textColor="@color/textPrimary" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Store-wise HU" android:textSize="9sp" android:textStyle="bold" android:textColor="@color/colorWarning" android:background="@color/colorWarningBg" android:paddingStart="7dp" android:paddingEnd="7dp" android:paddingTop="2dp" android:paddingBottom="2dp" />
                </LinearLayout>
                <LinearLayout android:id="@+id/ptl_hu_close" android:layout_width="0dp" android:layout_height="80dp" android:layout_weight="1" android:orientation="vertical" android:background="@color/bgCard" android:padding="14dp" android:layout_marginStart="4dp" android:clickable="true" android:focusable="true">
                    <TextView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:text="HU close" android:textSize="13sp" android:textStyle="bold" android:textColor="@color/textPrimary" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Close + print" android:textSize="9sp" android:textStyle="bold" android:textColor="#5B21B6" android:background="#F3E5F5" android:paddingStart="7dp" android:paddingEnd="7dp" android:paddingTop="2dp" android:paddingBottom="2dp" />
                </LinearLayout>
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <LinearLayout android:id="@+id/ptl_return_order_putaway" android:layout_width="0dp" android:layout_height="80dp" android:layout_weight="1" android:orientation="vertical" android:background="@color/bgCard" android:padding="14dp" android:layout_marginEnd="4dp" android:clickable="true" android:focusable="true">
                    <TextView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:text="Return putaway" android:textSize="13sp" android:textStyle="bold" android:textColor="@color/textPrimary" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Return orders" android:textSize="9sp" android:textStyle="bold" android:textColor="@color/textSecondary" android:background="@color/bgInput" android:paddingStart="7dp" android:paddingEnd="7dp" android:paddingTop="2dp" android:paddingBottom="2dp" />
                </LinearLayout>
                <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />
            </LinearLayout>
            <Button android:id="@+id/ptl_crate_to_msa" android:layout_width="match_parent" android:layout_height="wrap_content" android:visibility="gone" android:text="Crate to MSA" android:background="@drawable/bg_btn_primary" android:textColor="@color/white" android:textSize="13sp" />
            <Button android:id="@+id/ptl_pick_crate" android:layout_width="match_parent" android:layout_height="wrap_content" android:visibility="gone" android:text="Pick Crate" android:background="@drawable/bg_btn_primary" android:textColor="@color/white" android:textSize="13sp" />
        </LinearLayout>
    </ScrollView>
</FrameLayout>